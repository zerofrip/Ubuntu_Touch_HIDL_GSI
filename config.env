# =============================================================================
# config.env — Ubuntu GSI build configuration (HIDL variant)
# =============================================================================

# PHH Treble GSI base (HIDL repo defaults to Android 11 era)
PHH_GSI_SOURCE=release
PHH_GSI_REPO=phhusson/treble_experimentations
PHH_GSI_VERSION=v416
PHH_GSI_VARIANT=squeak-arm64-ab-vanilla
# PHH_GSI_URL=https://github.com/phhusson/treble_experimentations/releases/download/v416/system-squeak-arm64-ab-vanilla.img.xz
# PHH_GSI_LOCAL=/absolute/path/to/phh-gsi.img
# TREBLE_EXP_PATH=/home/zero/github/treble_experimentations
# PHH_CUSTOM_TARGET=android-14.0
# PHH_CUSTOM_VARIANT=td-arm64-ab-vanilla
# PHH_CUSTOM_SKIP_BUILD=0
# PHH_CUSTOM_OUTPUT=/absolute/path/to/system-td-arm64-ab-vanilla.img.xz
#
# Minimal custom PHH preset (recommended first try for size reduction):
# PHH_GSI_SOURCE=custom
# PHH_CUSTOM_TARGET=android-14.0
# PHH_CUSTOM_VARIANT=td-arm64-ab-vanilla

# Ubuntu chroot rootfs settings
ARCH=arm64
UBUNTU_SUITE=focal
UBUNTU_MIRROR=http://ports.ubuntu.com/ubuntu-ports

# EROFS compression (adjust if your kernel only supports plain lz4)
EROFS_COMP=lz4hc,9

# system.img size in MB (0 = auto content + headroom)
SYSTEM_IMG_SIZE_MB=0
# /system layout profile:
#   android-minimal = Android core skeleton + launcher + compat focused footprint
#   full            = keep full PHH payload
SYSTEM_LAYOUT_PROFILE=android-minimal
# Include rootfs seed under /system/usr/share/ubuntu-gsi (0=smaller system.img)
ROOTFS_SEED_IN_SYSTEM=0
# Rootfs prune level: empty/standard/aggressive (minimal profile defaults to aggressive)
# GSI_ROOTFS_PRUNE_LEVEL=aggressive
