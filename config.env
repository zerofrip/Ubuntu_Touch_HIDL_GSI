# =============================================================================
# config.env — Ubuntu GSI Build Configuration
# =============================================================================
# Source this file or let build.sh source it automatically.
# Override any value by exporting it before running build.sh.
# =============================================================================

# Ubuntu rootfs download URL (UBports Focal arm64)
ROOTFS_URL="${ROOTFS_URL:-https://ci.ubports.com/job/ubuntu-touch-rootfs/job/main/lastStableBuild/artifact/ubuntu-touch-android9plus-rootfs-arm64.tar.gz}"

# Rootfs tarball filename (relative to repo root)
ROOTFS_TARBALL_NAME="${ROOTFS_TARBALL_NAME:-ubuntu-touch-rootfs.tar.gz}"

# SquashFS compression algorithm: xz, gzip, lzo, lz4, zstd
SQUASHFS_COMP="${SQUASHFS_COMP:-xz}"

# system.img size in megabytes (0 = auto: content size + 8 MB headroom, minimum 16 MB)
SYSTEM_IMG_SIZE_MB="${SYSTEM_IMG_SIZE_MB:-0}"

# Target architecture
ARCH="${ARCH:-arm64}"

# SquashFS block size
SQUASHFS_BLOCK_SIZE="${SQUASHFS_BLOCK_SIZE:-1048576}"

# Userdata image size in megabytes (0 = auto: squashfs size + 64 MB headroom).
# The image is kept minimal and expanded to fill the full partition on first boot.
# This image is flashed to the userdata partition and contains the rootfs.
USERDATA_IMG_SIZE_MB="${USERDATA_IMG_SIZE_MB:-0}"
