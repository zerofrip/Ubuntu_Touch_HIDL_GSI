# =============================================================================
# rootfs/packages.list — Ubuntu Touch HIDL GSI Required Packages
# =============================================================================
# One package per line. Lines starting with # are comments.
# These packages are installed into the rootfs during build.
#
# This list targets the HIDL-only sibling of Ubuntu_GSI. Packages that
# matter specifically for HIDL HAL bridging (lshal helper, vendor
# firmware loaders, libhidl runtime stubs from AOSP) are noted inline.
# =============================================================================

# Core system
systemd
systemd-sysv
dbus
udev
sudo
bash
bash-completion
locales
ca-certificates

# Networking
network-manager
iproute2
iw
wpasupplicant
openssh-server
crda
wireless-regdb
rfkill

# VPN
openvpn
network-manager-openvpn
wireguard-tools
network-manager-vpnc

# WiFi Tethering
hostapd

# Telephony / Modem
ofono
ofono-scripts
modemmanager
libqmi-utils
libmbim-utils
usb-modeswitch
usb-modeswitch-data

# Input / Touchscreen
libinput10
libinput-bin
libinput-tools
libevdev2
libmtdev1
evtest

# HwBinder / HIDL / IPC support
# Note: libhidlbase / libhwbinder / hwservicemanager / lshal are NOT in
# Ubuntu repos. They are provided by the AOSP submodule under
# third_party/aosp_frameworks_native and are vendored into the rootfs
# at build time. libbinder-dev is kept only for legacy framework
# binder use cases (e.g. InputFlinger compatibility shims).
libbinder-dev

# Audio
pulseaudio
pulseaudio-utils
alsa-utils
alsa-base
libasound2
libasound2-plugins

# Sensors
iio-sensor-proxy

# Biometric authentication
fprintd
libpam-fprintd
# howdy — installed from PPA or source (not in Ubuntu main repos)

# GPS / GNSS
gpsd
gpsd-clients

# Bluetooth
bluez
bluetooth
pulseaudio-module-bluetooth

# Camera
libcamera0.3
libcamera-tools
libcamera-ipa
gstreamer1.0-libcamera
gstreamer1.0-plugins-base
gstreamer1.0-plugins-good
v4l-utils
# megapixels → lomiri-camera-app で代替

# Power
upower

# Storage
udisks2

# USB OTG / Host mode
usbutils
usb-modeswitch

# Web Browser (standalone)
firefox

# Utilities
jq
curl
grim

# GUI / Display
mir-graphics-drivers-desktop
mir-platform-graphics-wayland
libdrm2
libdrm-common
libgbm1
libegl1-mesa
libgles2-mesa
libgl1-mesa-dri
mesa-utils
libwayland-client0
libwayland-server0

