#!/system/bin/sh
# =============================================================================
# /system/bin/ubuntu-gsi-launcher — Halium-style chroot pivot (HIDL variant)
# =============================================================================
# Started by /system/etc/init/ubuntu-gsi.rc once
#
#   property:sys.boot_completed=1 && property:persist.ubuntu_gsi.enable=1
#
# Performs the following pivot:
#   1. Mount the Ubuntu rootfs.erofs from /data/ubuntu-gsi/ (system seed is fallback).
#   2. Layer overlayfs upper from /data/uhl_overlay/upper on top.
#   3. Bind-mount Android namespaces (/vendor, /dev, /sys, /proc,
#      /dev/binderfs, /dev/socket, /data, …) into the merged tree.
#   4. Stop SurfaceFlinger / bootanim so the GPU and FB are free.
#   5. nsenter --mount + chroot into the merged tree and exec systemd.
#
# Android stays alive underneath: zygote, hwservicemanager, every vendor HAL
# service and the binder devices keep running inside their original mount
# namespace. Mir (started by Lomiri inside the chroot) reaches the GPU via
# libhybris which dlopens the vendor EGL/GLES libraries through bind-mounted
# /vendor and /system_real.
#
# Exit codes:
#   0   chrooted successfully (this script never returns from a successful exec)
#   10  rootfs.erofs missing
#   11  overlayfs assembly failed
#   12  bind-mount failed
#   13  switch_root/chroot failed
# =============================================================================

set -eu

LOG_TAG="ubuntu-gsi-launcher"
log() {
    # Send to logcat so journalctl-style debugging works on Android side too.
    log -t "$LOG_TAG" "$*" 2>/dev/null || true
    echo "[$LOG_TAG] $*" 1>&2
}

fail() {
    rc=$1
    msg=$2
    log "FATAL ($rc): $msg"
    setprop persist.ubuntu_gsi.failed 1 2>/dev/null || true
    exit "$rc"
}

# -----------------------------------------------------------------------------
# Paths & tunables
# -----------------------------------------------------------------------------
SYSTEM_ROOTFS_EROFS="/system/usr/share/ubuntu-gsi/rootfs.erofs"
SYSTEM_ROOTFS_SHA256_FILE="/system/usr/share/ubuntu-gsi/rootfs.erofs.sha256"
DATA_ROOTFS_DIR="/data/ubuntu-gsi"
ROOTFS_EROFS="$DATA_ROOTFS_DIR/rootfs.erofs"
ROOTFS_EROFS_BAK="$DATA_ROOTFS_DIR/rootfs.erofs.bak"
ROOTFS_EROFS_SHA256_FILE="$DATA_ROOTFS_DIR/rootfs.erofs.sha256"
FIRSTBOOT_MARKER="/data/uhl_overlay/.firstboot_complete"
SETUP_WIZARD_PENDING="/data/uhl_overlay/.setup_wizard_pending"
OVERLAY_BASE="/halium/base"
OVERLAY_UPPER="/data/uhl_overlay/upper"
OVERLAY_WORK="/data/uhl_overlay/work"
OVERLAY_MERGED="/halium/merged"

mkdir -p "$OVERLAY_BASE" "$OVERLAY_UPPER" "$OVERLAY_WORK" "$OVERLAY_MERGED" \
         /halium /data/uhl_overlay "$DATA_ROOTFS_DIR" 2>/dev/null || true

sha256_bin() {
    if command -v sha256sum >/dev/null 2>&1; then
        echo "sha256sum"
        return 0
    fi
    if command -v toybox >/dev/null 2>&1; then
        echo "toybox sha256sum"
        return 0
    fi
    return 1
}

hash_file() {
    _f="$1"
    _bin="$(sha256_bin 2>/dev/null || true)"
    [ -n "$_bin" ] || return 1
    $_bin "$_f" 2>/dev/null | awk '{print $1}'
}

expected_rootfs_hash() {
    if [ -f "$ROOTFS_EROFS_SHA256_FILE" ]; then
        awk '{print $1}' "$ROOTFS_EROFS_SHA256_FILE" 2>/dev/null | head -n 1
        return 0
    fi
    if [ -f "$SYSTEM_ROOTFS_SHA256_FILE" ]; then
        awk '{print $1}' "$SYSTEM_ROOTFS_SHA256_FILE" 2>/dev/null | head -n 1
        return 0
    fi
    hash_file "$SYSTEM_ROOTFS_EROFS" || true
}

rootfs_valid() {
    _f="$1"
    [ -f "$_f" ] || return 1
    _exp="$(expected_rootfs_hash)"
    [ -n "$_exp" ] || return 0
    _got="$(hash_file "$_f" || true)"
    [ -n "$_got" ] || return 1
    [ "$_got" = "$_exp" ]
}

write_hash_file() {
    _f="$1"
    _hash="$(hash_file "$_f" || true)"
    [ -n "$_hash" ] || return 0
    echo "$_hash  rootfs.erofs" > "$ROOTFS_EROFS_SHA256_FILE"
}

restore_rootfs_from_system() {
    if [ ! -f "$SYSTEM_ROOTFS_EROFS" ]; then
        fail 10 "system seed rootfs missing at $SYSTEM_ROOTFS_EROFS (enable ROOTFS_SEED_IN_SYSTEM=1 or pre-provision /data/ubuntu-gsi/rootfs.erofs)"
    fi
    log "Restoring userdata rootfs from system seed"
    cp -f "$SYSTEM_ROOTFS_EROFS" "$ROOTFS_EROFS" || fail 10 "failed to restore rootfs from system seed"
    cp -f "$ROOTFS_EROFS" "$ROOTFS_EROFS_BAK" || true
    write_hash_file "$ROOTFS_EROFS"
}

ensure_userdata_rootfs() {
    if rootfs_valid "$ROOTFS_EROFS"; then
        log "Primary userdata rootfs is valid"
        [ -f "$ROOTFS_EROFS_BAK" ] || cp -f "$ROOTFS_EROFS" "$ROOTFS_EROFS_BAK" || true
        write_hash_file "$ROOTFS_EROFS"
        return 0
    fi

    log "Primary userdata rootfs missing/corrupt, trying backup"
    if rootfs_valid "$ROOTFS_EROFS_BAK"; then
        cp -f "$ROOTFS_EROFS_BAK" "$ROOTFS_EROFS" || fail 10 "failed to restore primary rootfs from backup"
        write_hash_file "$ROOTFS_EROFS"
        log "Restored primary userdata rootfs from backup"
        return 0
    fi

    log "Backup rootfs missing/corrupt, restoring from system seed"
    restore_rootfs_from_system
}

# Mark this run.
log "Halium-style launcher starting (HIDL variant)."
log "  rootfs:   $ROOTFS_EROFS"
log "  upper:    $OVERLAY_UPPER"
log "  merged:   $OVERLAY_MERGED"

# -----------------------------------------------------------------------------
# 1. Rootfs A/B self-heal on userdata + initial setup trigger
# -----------------------------------------------------------------------------
ensure_userdata_rootfs

if [ ! -f "$FIRSTBOOT_MARKER" ]; then
    log "First-boot marker missing — scheduling setup wizard"
    touch "$SETUP_WIZARD_PENDING" 2>/dev/null || true
fi

# -----------------------------------------------------------------------------
# 2. Erofs base mount
# -----------------------------------------------------------------------------

if ! mountpoint -q "$OVERLAY_BASE"; then
    log "Mounting rootfs.erofs (read-only) at $OVERLAY_BASE"
    mount -t erofs -o ro,loop "$ROOTFS_EROFS" "$OVERLAY_BASE" \
        || fail 10 "erofs mount failed"
fi

# -----------------------------------------------------------------------------
# 3. Snapshot rotation (1->2->3, GC > 3) — preserved from the previous arch
# -----------------------------------------------------------------------------
SNAP1="/data/uhl_overlay/snapshot.1"
SNAP2="/data/uhl_overlay/snapshot.2"
SNAP3="/data/uhl_overlay/snapshot.3"

if [ -f "/data/uhl_overlay/rollback" ]; then
    log "Rollback trigger detected → restoring snapshot.1"
    if [ -d "$SNAP1" ]; then
        rm -rf "$OVERLAY_UPPER" "$OVERLAY_WORK"
        cp -a "$SNAP1" "$OVERLAY_UPPER"
        mkdir -p "$OVERLAY_WORK"
        rm -f /data/uhl_overlay/rollback
        log "Rollback succeeded"
    else
        log "No snapshot.1 — rollback skipped"
    fi
else
    log "Rotating snapshots upper -> snapshot.1 -> 2 -> 3"
    [ -d "$SNAP3" ] && rm -rf "$SNAP3"
    [ -d "$SNAP2" ] && mv "$SNAP2" "$SNAP3"
    [ -d "$SNAP1" ] && mv "$SNAP1" "$SNAP2"
    [ -d "$OVERLAY_UPPER" ] && cp -a "$OVERLAY_UPPER" "$SNAP1"
fi

# -----------------------------------------------------------------------------
# 4. OverlayFS assembly
# -----------------------------------------------------------------------------
if ! mountpoint -q "$OVERLAY_MERGED"; then
    log "Assembling overlayfs"
    mount -t overlay overlay \
        -o "lowerdir=$OVERLAY_BASE,upperdir=$OVERLAY_UPPER,workdir=$OVERLAY_WORK" \
        "$OVERLAY_MERGED" \
        || fail 11 "overlay assembly failed"
fi

mountpoint -q "$OVERLAY_MERGED" || fail 11 "overlay validation failed"

# -----------------------------------------------------------------------------
# 5. Bind Android namespaces into the merged tree
# -----------------------------------------------------------------------------
bind() {
    src=$1; dst=$2; opts=${3:-}
    [ -e "$src" ] || { log "skip bind $src (missing)"; return 0; }
    [ -e "$OVERLAY_MERGED$dst" ] || mkdir -p "$OVERLAY_MERGED$dst" 2>/dev/null || true
    if [ -f "$src" ] && [ ! -d "$src" ]; then
        : > "$OVERLAY_MERGED$dst" 2>/dev/null || true
    fi
    case "$opts" in
        rec) mount --rbind "$src" "$OVERLAY_MERGED$dst" ;;
        *)   mount --bind  "$src" "$OVERLAY_MERGED$dst" ;;
    esac || fail 12 "bind $src -> $dst failed"
    log "bind $src -> $OVERLAY_MERGED$dst"
}

bind /vendor       /vendor
bind /system       /system_real
bind /dev          /dev          rec
bind /dev/binderfs /dev/binderfs rec
bind /proc         /proc         rec
bind /sys          /sys          rec
bind /data         /data
bind /data/uhl_overlay /var/lib/ubuntu-gsi
[ -d /dev/socket ] && bind /dev/socket /dev/socket rec || true
[ -d /mnt/vendor  ] && bind /mnt/vendor /mnt/vendor rec || true

# Make sure /halium itself is reachable from inside the chroot so the
# launcher can find its own log/state for diagnostics.
[ -d "$OVERLAY_MERGED/halium" ] || mkdir -p "$OVERLAY_MERGED/halium"
mount --rbind /halium "$OVERLAY_MERGED/halium" || true

# -----------------------------------------------------------------------------
# 6. Hand the GPU off
# -----------------------------------------------------------------------------
if [ -x /system/bin/ubuntu-gsi-stop-android-ui ]; then
    log "Stopping Android UI services for GPU hand-off"
    /system/bin/ubuntu-gsi-stop-android-ui || log "ui stop returned non-zero (continuing)"
fi

# -----------------------------------------------------------------------------
# 7. Sanity: systemd present?
# -----------------------------------------------------------------------------
SYSTEMD="/lib/systemd/systemd"
if [ ! -x "$OVERLAY_MERGED$SYSTEMD" ]; then
    fail 13 "systemd missing inside merged tree at $SYSTEMD"
fi

# -----------------------------------------------------------------------------
# 8. Pivot.
#
#    We use chroot rather than switch_root because Android init must keep
#    its own root mount; tearing it down would kill HAL services we still
#    rely on.  The chroot scopes only this process tree.
#
#    `nsenter --mount=/proc/self/ns/mnt` is a no-op but documents intent.
# -----------------------------------------------------------------------------
log "exec chroot -> systemd"
setprop persist.ubuntu_gsi.failed 0 2>/dev/null || true

# Pass the absolute log target; systemd will redirect its journal-kmsg
# stream into the kernel ring buffer where logcat -b kernel can read it.
exec chroot "$OVERLAY_MERGED" "$SYSTEMD" --log-target=kmsg --unit=graphical.target

# Should never reach here.
fail 13 "exec returned"
